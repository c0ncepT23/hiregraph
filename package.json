{
  "name": "hiregraph",
  "version": "0.2.0",
  "description": "Turn your code into job applications. Local-first CLI that scans codebases, builds skill graphs, and matches against jobs.",
  "type": "module",
  "bin": {
    "hiregraph": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "hiring",
    "resume",
    "code-analysis",
    "skill-graph",
    "job-search",
    "ats",
    "greenhouse",
    "lever",
    "ashby",
    "local-first",
    "byok",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "author": "HireGraph Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/c0ncepT23/hiregraph"
  },
  "homepage": "https://github.com/c0ncepT23/hiregraph#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "form-data": "^4.0.5",
    "ignore": "^7.0.5",
    "inquirer": "^13.3.2",
    "ora": "^5.4.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
