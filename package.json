{
  "name": "hiregraph",
  "version": "0.1.0",
  "description": "Turn your code into job applications. Local-first CLI that scans codebases, builds skill graphs, and matches against jobs.",
  "type": "module",
  "bin": {
    "hiregraph": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "hiring",
    "resume",
    "code-analysis",
    "skill-graph",
    "job-search"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "inquirer": "^13.3.2",
    "ora": "^5.4.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
